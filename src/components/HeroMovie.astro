---
import { Image } from 'astro:assets';
import { type LatestFeedVersion, getLatestMovies, parseFeedVersion } from '@/lib/phimapi';
import { getCachedValue, setCachedValue } from '@/lib/server-cache';
import { imagePresets, resolveImageUrl } from '@/lib/wsrv';

interface Props {
  feedVersion?: LatestFeedVersion;
}

const { feedVersion = 'v1' } = Astro.props as Props;
const selectedFeed = parseFeedVersion(feedVersion);
const HERO_CACHE_KEY = `hero:latest:${selectedFeed}`;
const HERO_CACHE_TTL_SECONDS = 3600 * 3;

type LatestFeedResponse = Awaited<ReturnType<typeof getLatestMovies>>;

let latestData = getCachedValue<LatestFeedResponse>(HERO_CACHE_KEY);

if (!latestData) {
  latestData = await getLatestMovies({ page: 1, feedVersion: selectedFeed });
  setCachedValue(HERO_CACHE_KEY, latestData, HERO_CACHE_TTL_SECONDS);
}

const items = latestData.items ?? [];

const featured = items.slice(0, 5);
const hasFeatured = featured.length > 0;
const heroPreset = imagePresets.hero;
type FeaturedItem = NonNullable<LatestFeedResponse['items']>[number];

const normalizeHeroToken = (value: unknown) => {
  if (typeof value !== 'string') return null;
  const normalized = value.trim();
  return normalized.length ? normalized : null;
};

const getHeroMetaTokens = (item: FeaturedItem) => {
  const tokens: string[] = [];
  if ('quality' in item) {
    const quality = normalizeHeroToken(item.quality);
    if (quality) tokens.push(quality.toUpperCase());
  }
  if ('lang' in item) {
    const lang = normalizeHeroToken(item.lang);
    if (lang) tokens.push(lang);
  }
  if ('episode_current' in item) {
    const episode = normalizeHeroToken(item.episode_current);
    if (episode) tokens.push(episode);
  }
  if ('time' in item) {
    const runtime = normalizeHeroToken(item.time);
    if (runtime) tokens.push(runtime);
  }
  if ('category' in item && Array.isArray(item.category) && item.category.length) {
    const primaryCategory = normalizeHeroToken(item.category[0]?.name);
    if (primaryCategory) tokens.push(primaryCategory);
  }
  return tokens.slice(0, 4);
};
---

<section
    class="relative mx-auto flex w-full flex-col gap-6 px-0 pb-8 pt-3 sm:gap-8 sm:pb-10"
>
    {/* Quick play latest button */}
    {
        hasFeatured ? (
            <div class="relative overflow-hidden border-2 border-[#3F3F46] bg-[#09090B]" data-carousel="hero">
                <div class="relative min-h-[27rem] overflow-hidden sm:min-h-[28rem] md:min-h-[32rem] lg:min-h-[34rem]">
                    {featured.map((item, index) => (
                        <article
                            class={`absolute inset-0 h-full w-full transition-opacity duration-1000 ${
                                index === 0
                                    ? "z-20 opacity-100"
                                    : "z-10 pointer-events-none opacity-0"
                            }`}
                            data-slide
                            data-index={index}
                            aria-hidden={index === 0 ? "false" : "true"}
                        >
                            <div class="absolute inset-0 overflow-hidden">
                                {(() => {
                                    const imageSource = resolveImageUrl(item?.thumb_url ?? item?.poster_url);
                                    if (!imageSource) return null;

                                    return (
                                        <Image
                                            src={imageSource}
                                            alt={item.name}
                                            width={heroPreset.dimension.width}
                                            height={heroPreset.dimension.height}
                                            widths={heroPreset.widths}
                                            sizes={heroPreset.sizes}
                                            quality={heroPreset.quality}
                                            fit="cover"
                                            loading={index === 0 ? "eager" : "lazy"}
                                            fetchpriority={index === 0 ? "high" : "auto"}
                                            class="pointer-events-none h-full w-full object-cover opacity-85"
                                            style="mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 0.72) 58%, rgba(0, 0, 0, 0.42) 100%);"
                                        />
                                    );
                                })()}
                                <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_26%,rgba(223,225,4,0.2),transparent_42%),radial-gradient(circle_at_78%_12%,rgba(255,255,255,0.08),transparent_38%)]" />
                                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[#09090B] via-[#09090B]/58 to-transparent" />
                                <div class="pointer-events-none absolute inset-y-0 left-0 w-[72%] bg-gradient-to-r from-[#09090B]/88 via-[#09090B]/54 to-transparent" />
                            </div>

                            <div class="relative grid h-full grid-rows-[auto_1fr_auto] px-4 pb-16 pt-6 sm:px-8 sm:pb-16 sm:pt-10 md:px-12 lg:px-16">
                                <div class="flex items-center justify-between gap-3">
                                    <span class="inline-flex border border-[#DFE104] bg-[#DFE104] px-3 py-1 text-[10px] font-bold uppercase tracking-[0.24em] text-[#09090B] sm:px-4 sm:py-1.5 sm:text-xs">
                                        Mới cập nhật
                                    </span>
                                    <span class="inline-flex border border-[#3F3F46] bg-[#09090B]/75 px-3 py-1 text-[10px] font-bold uppercase tracking-[0.18em] text-[#A1A1AA] sm:text-xs sm:tracking-[0.2em]">
                                        {String(item.year)}
                                    </span>
                                </div>

                                <div class="self-end space-y-3 pb-4 sm:space-y-4 sm:pb-5">
                                    <div class="w-full max-w-[20rem] space-y-2 sm:mx-0 sm:max-w-[46rem] sm:space-y-3 min-h-[8.5rem] sm:min-h-[11rem] lg:min-h-[13rem]">
                                        <h1 class="max-w-[16ch] line-clamp-2 text-[1.8rem] font-bold uppercase tracking-tight leading-[0.96] text-[#FAFAFA] drop-shadow-[0_2px_0_rgba(0,0,0,0.35)] sm:max-w-[16ch] sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl">
                                            {item.name}
                                        </h1>
                                        <p class="line-clamp-2 min-h-[1.25rem] text-[11px] uppercase tracking-[0.16em] text-[#A1A1AA] sm:line-clamp-1 sm:min-h-[1.5rem] sm:text-sm sm:tracking-[0.22em] md:text-base">
                                            {item.origin_name}
                                        </p>
                                    </div>

                                    <div class="flex min-h-[1.8rem] flex-wrap items-center gap-1.5 sm:gap-2">
                                        {getHeroMetaTokens(item).map((token) => (
                                            <span class="inline-flex items-center border border-[#3F3F46] bg-[#09090B]/82 px-2 py-1 text-[9px] font-bold uppercase tracking-[0.14em] text-[#FAFAFA] sm:px-2.5 sm:text-[10px] sm:tracking-[0.16em]">
                                                {token}
                                            </span>
                                        ))}
                                    </div>
                                </div>

                                <div class="flex flex-col items-stretch gap-2.5 sm:flex-row sm:flex-wrap sm:items-center sm:justify-start sm:gap-4">
                                    <a
                                        href={`/phim/${item.slug}?autoplay=1`}
                        id="watchBtn"
                        type="button"
                        class="w-full sm:w-auto sm:flex-none uppercase tracking-tighter font-bold bg-[#DFE104] text-black px-5 py-3 md:px-6 md:py-3 hover:scale-105 transition-all inline-flex items-center justify-center gap-2 disabled:opacity-40 disabled:cursor-not-allowed focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#DFE104] focus-visible:ring-offset-2 focus-visible:ring-offset-[#09090B] min-h-11 min-w-[140px]"
                    >
                        <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M8 5v14l11-7z"/>
                        </svg>
                        Xem ngay
                    </a>
                                    <a
                                        href={`/phim/${item.slug}?autoplay=1`}
                                        class="inline-flex w-full sm:w-auto items-center justify-center gap-2 border-2 border-[#3F3F46] bg-[#09090B]/74 px-6 py-3 text-xs font-bold uppercase tracking-[0.18em] text-[#FAFAFA] transition-all duration-300 hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-[#09090B] focus:outline-none focus:ring-2 focus:ring-[#DFE104] focus:ring-offset-2 focus:ring-offset-[#09090B] min-h-11 sm:px-8 sm:py-3 sm:text-sm sm:tracking-[0.2em]"
                                        tabindex={index === 0 ? "0" : "-1"}
                                    >
                                        Chi tiết
                                    </a>
                                </div>
                            </div>
                        </article>
                    ))}
                </div>

                {featured.length > 1 && (
                    <>
                        <div class="pointer-events-auto absolute inset-y-0 left-0 z-40 hidden items-center px-2 sm:flex sm:px-3">
                            <button
                                type="button"
                                class="z-50 inline-flex h-10 w-10 items-center justify-center border border-[#3F3F46] bg-[#09090B]/82 text-[#FAFAFA] backdrop-blur-sm transition-all duration-300 hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-[#09090B] focus:outline-none focus:ring-2 focus:ring-[#DFE104] focus:ring-offset-2 focus:ring-offset-[#09090B] sm:h-11 sm:w-11"
                                data-prev
                                aria-label="Phim trước"
                            >
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="pointer-events-auto absolute inset-y-0 right-0 z-40 hidden items-center px-2 sm:flex sm:px-3">
                            <button
                                type="button"
                                class="z-50 inline-flex h-10 w-10 items-center justify-center border border-[#3F3F46] bg-[#09090B]/82 text-[#FAFAFA] backdrop-blur-sm transition-all duration-300 hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-[#09090B] focus:outline-none focus:ring-2 focus:ring-[#DFE104] focus:ring-offset-2 focus:ring-offset-[#09090B] sm:h-11 sm:w-11"
                                data-next
                                aria-label="Phim tiếp"
                            >
                                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                </svg>
                            </button>
                        </div>
                        <div class="pointer-events-none absolute inset-x-0 bottom-4 z-40 flex justify-center gap-2">
                            <div class="flex items-center space-x-2">
                                {featured.map((item, index) => (
                                    <button
                                        type="button"
                                        class={`pointer-events-auto h-1.5 transition-all duration-300 ${
                                            index === 0
                                                ? "w-10 bg-[#DFE104]"
                                                : "w-4 bg-[#3F3F46] hover:bg-[#A1A1AA]"
                                        }`}
                                        data-dot
                                        data-index={index}
                                        aria-label={`Chuyển tới phim ${item.name}`}
                                    />
                                ))}
                            </div>
                        </div>
                        <div class="pointer-events-none absolute bottom-3 right-3 z-40 border border-[#3F3F46] bg-[#09090B]/80 px-2.5 py-1 text-[9px] font-bold uppercase tracking-[0.16em] text-[#A1A1AA] backdrop-blur-sm sm:bottom-4 sm:right-4 sm:px-4 sm:py-2 sm:text-xs sm:tracking-[0.2em]">
                            <span class="text-[#DFE104]" data-current>1</span> / <span data-total>{featured.length}</span>
                        </div>
                    </>
                )}
            </div>
        ) : (
            <div class="border-2 border-[#3F3F46] bg-[#09090B] p-12 text-center text-sm text-[#A1A1AA]">
                Không thể tải dữ liệu phim mới. Vui lòng thử lại sau.
            </div>
        )
    }

    {featured.length > 1 && (
        <script is:inline>
            const heroCarousel = document.querySelector('[data-carousel="hero"]');
            if (heroCarousel) {
                const slides = Array.from(heroCarousel.querySelectorAll('[data-slide]'));
                const dots = Array.from(heroCarousel.querySelectorAll('[data-dot]'));
                const prevButton = heroCarousel.querySelector('[data-prev]');
                const nextButton = heroCarousel.querySelector('[data-next]');
                const currentIndicator = heroCarousel.querySelector('[data-current]');
                let activeIndex = 0;
                let touchStartX = 0;
                let touchDeltaX = 0;

                const updateIndicators = () => {
                    if (currentIndicator) {
                        currentIndicator.textContent = (activeIndex + 1).toString();
                    }
                };

                const toggleSlide = (index) => {
                    if (!slides.length) return;
                    activeIndex = (index + slides.length) % slides.length;

                    slides.forEach((slide, slideIndex) => {
                        const isActive = slideIndex === activeIndex;
                        slide.classList.toggle('opacity-0', !isActive);
                        slide.classList.toggle('pointer-events-none', !isActive);
                        slide.classList.toggle('opacity-100', isActive);
                        slide.classList.toggle('z-20', isActive);
                        slide.classList.toggle('z-10', !isActive);
                        slide.setAttribute('aria-hidden', (!isActive).toString());

                        // Update tabindex for all links in the slide
                        const links = slide.querySelectorAll('a');
                        links.forEach(link => {
                            link.setAttribute('tabindex', isActive ? '0' : '-1');
                        });
                    });

                    dots.forEach((dot, dotIndex) => {
                        const isActive = dotIndex === activeIndex;
                        dot.classList.toggle('bg-[#DFE104]', isActive);
                        dot.classList.toggle('bg-[#3F3F46]', !isActive);
                        dot.classList.toggle('w-10', isActive);
                        dot.classList.toggle('w-4', !isActive);
                        dot.setAttribute('aria-pressed', isActive.toString());
                    });

                    updateIndicators();
                };

                const handleNext = () => toggleSlide(activeIndex + 1);
                const handlePrev = () => toggleSlide(activeIndex - 1);
                const SWIPE_THRESHOLD_PX = 44;

                let autoIntervalId;
                const clearAuto = () => {
                    if (autoIntervalId) {
                        clearInterval(autoIntervalId);
                        autoIntervalId = undefined;
                    }
                };
                const startAuto = () => {
                    clearAuto();
                    autoIntervalId = window.setInterval(handleNext, 5000);
                };
                const restartAuto = () => {
                    startAuto();
                };

                nextButton?.addEventListener('click', handleNext);
                prevButton?.addEventListener('click', handlePrev);
                dots.forEach((dot) => {
                    dot.addEventListener('click', () => {
                        const index = Number.parseInt(dot.dataset.index ?? '0', 10);
                        toggleSlide(index);
                    });
                });

                // optional: keyboard arrow support when carousel focused
                heroCarousel.addEventListener('keydown', (event) => {
                    if (event.key === 'ArrowRight') {
                        event.preventDefault();
                        handleNext();
                        restartAuto();
                    }
                    if (event.key === 'ArrowLeft') {
                        event.preventDefault();
                        handlePrev();
                        restartAuto();
                    }
                });
                heroCarousel.addEventListener('touchstart', (event) => {
                    touchStartX = event.changedTouches[0]?.clientX ?? 0;
                    touchDeltaX = 0;
                }, { passive: true });
                heroCarousel.addEventListener('touchmove', (event) => {
                    const currentX = event.changedTouches[0]?.clientX ?? touchStartX;
                    touchDeltaX = currentX - touchStartX;
                }, { passive: true });
                heroCarousel.addEventListener('touchend', () => {
                    if (Math.abs(touchDeltaX) < SWIPE_THRESHOLD_PX) return;
                    if (touchDeltaX < 0) {
                        handleNext();
                    } else {
                        handlePrev();
                    }
                    restartAuto();
                }, { passive: true });

                heroCarousel.setAttribute('tabindex', '0');
                nextButton?.addEventListener('click', restartAuto);
                prevButton?.addEventListener('click', restartAuto);
                dots.forEach((dot) => {
                    dot.addEventListener('click', restartAuto);
                });
                heroCarousel.addEventListener('mouseenter', clearAuto);
                heroCarousel.addEventListener('mouseleave', startAuto);
                heroCarousel.addEventListener('focusin', clearAuto);
                heroCarousel.addEventListener('focusout', startAuto);
                document.addEventListener('visibilitychange', () => {
                    if (document.hidden) {
                        clearAuto();
                    } else {
                        startAuto();
                    }
                });

                updateIndicators();
                startAuto();
            }
        </script>
    )}
</section>
