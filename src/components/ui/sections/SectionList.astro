---
import SectionListCarousel from "@/components/ui/SectionListCarousel";
import { getSectionData } from "./section-utils";

const { config } = Astro.props;

const section = await getSectionData(config);
---

<section class="flex flex-col gap-5 border-t border-[#27272A] pt-8 sm:gap-6 sm:pt-10" id={section.key}>
    <div class="flex flex-wrap items-end justify-between gap-3">
        <div class="space-y-1">
            <h2 class="text-2xl font-bold uppercase tracking-tighter text-[#FAFAFA] sm:text-[2rem]">
                {section.title}
            </h2>
            <p class="text-xs uppercase tracking-[0.14em] text-[#A1A1AA] sm:text-sm">
                {section.subtitle}
            </p>
        </div>
        <a
            href={`/danh-sach/${section.typeList}`}
            class="group/link inline-flex items-center gap-1 border border-[#3F3F46] bg-[#09090B] px-3 py-1 text-[11px] font-bold uppercase tracking-[0.16em] text-[#FAFAFA] transition-all duration-300 hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-[#09090B]"
        >
            Xem tất cả
            <span class="inline-block transition-transform duration-300 group-hover/link:translate-x-1">→</span>
        </a>
    </div>

    {
        section.items.length ? (
            <SectionListCarousel
                client:visible
                items={section.items}
                layout={section.layout}
            />
        ) : (
            <div class="border-2 border-[#3F3F46] bg-[#09090B] px-6 py-12 text-center text-sm text-[#A1A1AA]">
                {section.error ?? "Không có dữ liệu để hiển thị."}
            </div>
        )
    }
</section>
