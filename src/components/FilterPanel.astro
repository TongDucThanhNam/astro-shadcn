---
import { FilterPanelMobile } from '@/components/FilterPanelMobile';
import { getCategoryTaxonomy, getCountryTaxonomy, parseListQuery } from '@/lib/phimapi';

interface Props {
  currentType: string;
  currentPage?: number;
  basePath?: string;
}

const { currentType, currentPage = 1, basePath = '/danh-sach/the-loai' } = Astro.props;

const url = new URL(Astro.request.url);
const query = parseListQuery(url.searchParams, { limit: 10 });

const sortField = query.sortField;
const sortType = query.sortType;
const category = query.category || '';
const country = query.country || '';
const year = query.year || '';
const limit = query.limit;

type Option = {
  name: string;
  slug: string;
};

const [categoryData, countryData] = await Promise.all([
  getCategoryTaxonomy(),
  getCountryTaxonomy(),
]);

const categoryOptions: Option[] = categoryData.map((item) => ({
  name: item.name,
  slug: item.slug,
}));

const countryOptions: Option[] = countryData.map((item) => ({
  name: item.name,
  slug: item.slug,
}));

const currentYear = new Date().getFullYear();
const years = Array.from({ length: 55 }, (_, i) => currentYear - i);

const sortFieldLabels: Record<string, string> = {
  'modified.time': 'Ngày cập nhật',
  _id: 'ID phim',
  year: 'Năm phát hành',
};

const sortTypeLabels: Record<string, string> = {
  desc: 'Mới nhất',
  asc: 'Cũ nhất',
};

const findOptionLabel = (value: string, options: Option[]) =>
  options.find((item) => item.slug === value)?.name ||
  value
    .split('-')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');

const activeFilters = [
  {
    key: 'sort',
    label: 'Sắp xếp',
    value: `${sortFieldLabels[sortField] || sortField} • ${sortTypeLabels[sortType] || sortType}`,
    removable: false,
  },
  category && {
    key: 'category',
    label: 'Thể loại',
    value: findOptionLabel(category, categoryOptions),
    removable: true,
  },
  country && {
    key: 'country',
    label: 'Quốc gia',
    value: findOptionLabel(country, countryOptions),
    removable: true,
  },
  year && {
    key: 'year',
    label: 'Năm',
    value: year,
    removable: true,
  },
  limit !== 10 && {
    key: 'limit',
    label: 'Kết quả',
    value: `${limit}/trang`,
    removable: true,
  },
].filter(Boolean) as { key: string; label: string; value: string; removable: boolean }[];
---

<div
    class="relative w-full overflow-hidden border-2 border-[#3F3F46] bg-[#09090B]"
    id="filterPanelContainer"
>
    <div class="relative p-4 md:p-6 lg:p-8">
        <div
            class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between"
        >
            <div class="space-y-2">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <h3 class="text-xl font-bold uppercase tracking-tighter text-[#FAFAFA]">
                            Bộ lọc
                        </h3>
                        <div class="absolute -bottom-1 left-0 h-0.5 w-8 bg-[#DFE104]"></div>
                    </div>
                    {
                        activeFilters.length > 0 && (
                            <span class="flex h-5 items-center justify-center bg-[#DFE104] px-2 text-xs font-bold uppercase tracking-tighter text-black animate-pulse">
                                {activeFilters.length}
                            </span>
                        )
                    }
                </div>
                <p class="text-sm text-[#A1A1AA]">
                    Tinh chỉnh danh sách phim để tìm nội dung phù hợp nhất với
                    bạn.
                </p>
            </div>
            <div class="flex flex-wrap items-center gap-2 md:hidden">
                {
                    activeFilters.length ? (
                        activeFilters.slice(0, 2).map(({ key, label, value, removable }) => (
                            <button
                                type="button"
                                data-filter-key={key}
                                class={`group flex items-center gap-2 border-2 border-[#3F3F46] bg-[#27272A] px-3 py-1.5 text-xs font-semibold uppercase tracking-tighter text-[#FAFAFA] transition-all duration-300 ${
                                    removable
                                        ? "hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-black hover:scale-105"
                                        : "cursor-default opacity-70"
                                }`}
                                {...(removable ? { "aria-label": `Xóa bộ lọc ${label}` } : {})}
                            >
                                <span class="text-[#A1A1AA] transition-colors group-hover:text-black/70">
                                    {label}
                                </span>
                                <span class="font-bold">{value}</span>
                                {
                                    removable && (
                                        <svg
                                            class="h-3 w-3 opacity-50 transition-all group-hover:opacity-100 group-hover:rotate-90"
                                            viewBox="0 0 10 10"
                                            fill="none"
                                            xmlns="http://www.w3.org/2000/svg"
                                        >
                                            <path
                                                d="M1 1L9 9M1 9L9 1"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                            ></path>
                                        </svg>
                                    )
                                }
                            </button>
                        ))
                    ) : (
                        <span class="flex items-center gap-2 text-xs uppercase tracking-widest text-[#A1A1AA]">
                            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            Chưa áp dụng bộ lọc
                        </span>
                    )
                }
                {
                    activeFilters.length > 2 && (
                        <span class="flex h-6 items-center justify-center rounded-sm bg-[#3F3F46] px-2 text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]">
                            +{activeFilters.length - 2}
                        </span>
                    )
                }
                {
                    activeFilters.some((f) => f.removable) && (
                        <button
                            type="button"
                            id="clearAllFilters"
                            class="group flex items-center gap-1.5 border-2 border-transparent px-3 py-1.5 text-xs font-bold uppercase tracking-tighter text-[#DFE104] transition-all hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-black"
                        >
                            <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 8h12M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Xóa
                        </button>
                    )
                }
            </div>
            <div class="hidden md:flex flex-wrap items-center gap-2">
                {
                    activeFilters.length ? (
                        activeFilters.map(({ key, label, value, removable }) => (
                            <button
                                type="button"
                                data-filter-key={key}
                                class={`group flex items-center gap-2 border-2 border-[#3F3F46] bg-[#27272A] px-3 py-1.5 text-xs font-semibold uppercase tracking-tighter text-[#FAFAFA] transition-all duration-300 ${
                                    removable
                                        ? "hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-black hover:scale-105"
                                        : "cursor-default opacity-70"
                                }`}
                                {...(removable ? { "aria-label": `Xóa bộ lọc ${label}` } : {})}
                            >
                                <span class="text-[#A1A1AA] transition-colors group-hover:text-black/70">
                                    {label}
                                </span>
                                <span class="font-bold">{value}</span>
                                {
                                    removable && (
                                        <svg
                                            class="h-3 w-3 opacity-50 transition-all group-hover:opacity-100 group-hover:rotate-90"
                                            viewBox="0 0 10 10"
                                            fill="none"
                                            xmlns="http://www.w3.org/2000/svg"
                                        >
                                            <path
                                                d="M1 1L9 9M1 9L9 1"
                                                stroke="currentColor"
                                                stroke-width="1.5"
                                                stroke-linecap="round"
                                            ></path>
                                        </svg>
                                    )
                                }
                            </button>
                        ))
                    ) : (
                        <span class="flex items-center gap-2 text-xs uppercase tracking-widest text-[#A1A1AA]">
                            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 4h12M2 8h12M2 12h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                            </svg>
                            Chưa áp dụng bộ lọc
                        </span>
                    )
                }
                {
                    activeFilters.some((f) => f.removable) && (
                        <button
                            type="button"
                            id="clearAllFilters"
                            class="group ml-2 flex items-center gap-1.5 border-2 border-transparent px-3 py-1.5 text-xs font-bold uppercase tracking-tighter text-[#DFE104] transition-all hover:border-[#DFE104] hover:bg-[#DFE104] hover:text-black"
                        >
                            <svg class="h-3.5 w-3.5 transition-transform group-hover:rotate-180" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2 8h12M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Xóa tất cả
                        </button>
                    )
                }
            </div>
        </div>

        <div class="mt-6 flex items-center justify-between gap-3">
            <div class="flex items-center gap-2">
                <span
                    class="text-xs font-semibold uppercase tracking-widest text-[#A1A1AA]"
                >
                    Tuỳ chỉnh
                </span>
                <div class="hidden h-px flex-1 bg-[#3F3F46] md:block"></div>
            </div>
        </div>

        <div class="md:hidden mt-4">
            <FilterPanelMobile client:load
                basePath={basePath}
                currentType={currentType}
                years={years}
                categoryOptions={categoryOptions}
                countryOptions={countryOptions}
                sortField={sortField}
                sortType={sortType}
                category={category}
                country={country}
                year={year}
                limit={limit}
            />
        </div>

        <div class="hidden md:block md:mt-8">
            <form
                id="filterFormDesktop"
                class="space-y-6"
            >
            <fieldset class="space-y-3 border border-[#3F3F46]/50 bg-[#18181B]/30 p-4">
                <legend
                    class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#A1A1AA]"
                >
                    <svg class="h-4 w-4 text-[#DFE104]" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2 4h12M2 8h12M2 12h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Sắp xếp & hiển thị
                </legend>
                <div
                    class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4"
                >
                    <div class="flex flex-col gap-2">
                        <label
                            for="sortFieldDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]"
                            >Sắp xếp theo</label
                        >
                        <select
                            id="sortFieldDesktop"
                            name="sortField"
                            value={sortField}
                            class="w-full border-2 border-[#3F3F46] bg-[#27272A] px-3 py-3.5 text-sm text-[#FAFAFA] transition-all duration-300 focus:border-[#DFE104] focus:shadow-[0_0_0_2px_rgba(223,225,4,0.3)] focus:outline-none active:scale-[0.99]"
                        >
                            <option value="modified.time">Ngày cập nhật</option>
                            <option value="_id">ID phim</option>
                            <option value="year">Năm phát hành</option>
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="sortTypeDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]"
                            >Thứ tự</label
                        >
                        <select
                            id="sortTypeDesktop"
                            name="sortType"
                            value={sortType}
                            class="w-full border-2 border-[#3F3F46] bg-[#27272A] px-3 py-3.5 text-sm text-[#FAFAFA] transition-all duration-300 focus:border-[#DFE104] focus:shadow-[0_0_0_2px_rgba(223,225,4,0.3)] focus:outline-none active:scale-[0.99]"
                        >
                            <option value="desc">Mới nhất</option>
                            <option value="asc">Cũ nhất</option>
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="yearDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]"
                            >Năm phát hành</label
                        >
                        <select
                            id="yearDesktop"
                            name="year"
                            value={year}
                            class="w-full border-2 border-[#3F3F46] bg-[#27272A] px-3 py-3.5 text-sm text-[#FAFAFA] transition-all duration-300 focus:border-[#DFE104] focus:shadow-[0_0_0_2px_rgba(223,225,4,0.3)] focus:outline-none active:scale-[0.99]"
                        >
                            <option value="">Tất cả</option>
                            {
                                years.map((y) => (
                                    <option value={String(y)}>{y}</option>
                                ))
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="limitDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]"
                            >Số lượng/trang</label
                        >
                        <select
                            id="limitDesktop"
                            name="limit"
                            value={limit}
                            class="w-full border-2 border-[#3F3F46] bg-[#27272A] px-3 py-3.5 text-sm text-[#FAFAFA] transition-all duration-300 focus:border-[#DFE104] focus:shadow-[0_0_0_2px_rgba(223,225,4,0.3)] focus:outline-none active:scale-[0.99]"
                        >
                            <option value="10">10</option>
                            <option value="20">20</option>
                            <option value="30">30</option>
                            <option value="40">40</option>
                            <option value="50">50</option>
                            <option value="60">60</option>
                        </select>
                    </div>
                </div>
            </fieldset>

            <fieldset class="space-y-3 border border-[#3F3F46]/50 bg-[#18181B]/30 p-4">
                <legend
                    class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-[#A1A1AA]"
                >
                    <svg class="h-4 w-4 text-[#DFE104]" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="5" cy="5" r="2" stroke="currentColor" stroke-width="1.5"/>
                        <circle cx="11" cy="11" r="2" stroke="currentColor" stroke-width="1.5"/>
                        <path d="M7 5h2M9 11h2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                    Bộ lọc nội dung
                </legend>
                <div
                    class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3"
                >
                    <div class="flex flex-col gap-2">
                        <label
                            for="categoryDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]"
                            >Thể loại</label
                        >
                        <select
                            id="categoryDesktop"
                            name="category"
                            value={category}
                            class="w-full border-2 border-[#3F3F46] bg-[#27272A] px-3 py-3.5 text-sm text-[#FAFAFA] transition-all duration-300 focus:border-[#DFE104] focus:shadow-[0_0_0_2px_rgba(223,225,4,0.3)] focus:outline-none active:scale-[0.99]"
                        >
                            <option value="">Tất cả</option>
                            {
                                categoryOptions.map((option) => (
                                    <option value={option.slug}>
                                        {option.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="countryDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#FAFAFA]"
                            >Quốc gia</label
                        >
                        <select
                            id="countryDesktop"
                            name="country"
                            value={country}
                            class="w-full border-2 border-[#3F3F46] bg-[#27272A] px-3 py-3.5 text-sm text-[#FAFAFA] transition-all duration-300 focus:border-[#DFE104] focus:shadow-[0_0_0_2px_rgba(223,225,4,0.3)] focus:outline-none active:scale-[0.99]"
                        >
                            <option value="">Tất cả</option>
                            {
                                countryOptions.map((option) => (
                                    <option value={option.slug}>
                                        {option.name}
                                    </option>
                                ))
                            }
                        </select>
                    </div>

                    <div class="flex flex-col gap-2">
                        <label
                            for="languageDesktop"
                            class="text-xs font-bold uppercase tracking-tighter text-[#71717A]"
                            >Ngôn ngữ</label
                        >
                        <select
                            id="languageDesktop"
                            disabled
                            class="relative w-full cursor-not-allowed border-2 border-dashed border-[#3F3F46]/50 bg-[#18181B] px-3 py-3.5 text-sm text-[#52525B]"
                        >
                            <option value="">Sắp ra mắt...</option>
                        </select>
                    </div>
                </div>
            </fieldset>

            <div
                class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:justify-end"
            >
                <button
                    type="reset"
                    class="group inline-flex w-full items-center justify-center gap-2 border-2 border-[#3F3F46] bg-transparent px-4 py-3.5 text-sm font-bold uppercase tracking-tighter text-[#FAFAFA] transition-all duration-300 hover:border-white hover:bg-white hover:text-black active:scale-95 sm:w-auto"
                >
                    <svg class="h-4 w-4 transition-transform group-hover:-rotate-180" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M2 8h12M8 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Đặt lại
                </button>
                <button
                    type="submit"
                    class="group inline-flex w-full items-center justify-center gap-2 bg-[#DFE104] px-4 py-3.5 text-sm font-bold uppercase tracking-tighter text-black transition-all duration-300 hover:scale-105 hover:shadow-[0_0_20px_rgba(223,225,4,0.5)] active:scale-[0.98] sm:w-auto"
                >
                    <svg class="h-4 w-4 transition-transform group-hover:scale-110" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 8l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Áp dụng bộ lọc
                </button>
            </div>
            </form>
        </div>
    </div>
</div>
