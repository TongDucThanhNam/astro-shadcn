---
interface Props {
  title: string;
}
const { title } = Astro.props;

import { ClientRouter } from 'astro:transitions';

import '@/styles/globals.css';
import { GenreDialog } from '@/components/GenreDialog';
import MobileMenu from '@/components/MobileMenu';
import SearchForm from '@/components/SearchForm';
import Cursor from '@/components/ui/Cursor';

const primaryLinks = [
  { label: 'Phim lẻ', href: '/danh-sach/phim-le' },
  { label: 'Phim bộ', href: '/danh-sach/phim-bo' },
  { label: 'TV Shows', href: '/danh-sach/tv-shows' },
];

const genreLinks = [
  { label: 'Hành Động', href: '/danh-sach/the-loai/hanh-dong' },
  { label: 'Tình Cảm', href: '/danh-sach/the-loai/tinh-cam' },
  { label: 'Cổ Trang', href: '/danh-sach/the-loai/co-trang' },
  { label: 'Kinh Dị', href: '/danh-sach/the-loai/kinh-di' },
  { label: 'Hài Hước', href: '/danh-sach/the-loai/hai-huoc' },
  { label: 'Viễn Tưởng', href: '/danh-sach/the-loai/vien-tuong' },
  { label: 'Phiêu Lưu', href: '/danh-sach/the-loai/phieu-luu' },
  { label: 'Bí Ẩn', href: '/danh-sach/the-loai/bi-an' },
];

const yearLinks = [
  { label: '2026', href: '/danh-sach/nam/2026' },
  { label: '2025', href: '/danh-sach/nam/2025' },
  { label: '2024', href: '/danh-sach/nam/2024' },
  { label: '2023', href: '/danh-sach/nam/2023' },
  { label: '2022', href: '/danh-sach/nam/2022' },
];
---

<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="AstroFilm - Xem phim online miễn phí" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
        <script is:inline>
            (() => {
                if (typeof window === 'undefined') return;
                if (window.__movieTransitionWaitInstalled) return;
                window.__movieTransitionWaitInstalled = true;

                const prewarmedImages = new Map();

                const warmImage = (src, srcset, sizes) => {
                    if (!src) return Promise.resolve();

                    const key = `${src}|${srcset || ''}|${sizes || ''}`;
                    if (prewarmedImages.has(key)) {
                        return prewarmedImages.get(key);
                    }

                    const promise = new Promise((resolve) => {
                        const img = new Image();
                        let settled = false;
                        const timeout = window.setTimeout(() => {
                            done();
                        }, 2500);
                        const done = () => {
                            if (settled) return;
                            settled = true;
                            window.clearTimeout(timeout);
                            resolve();
                        };

                        img.onload = done;
                        img.onerror = done;

                        if (srcset) img.srcset = srcset;
                        if (sizes) img.sizes = sizes;
                        img.src = src;

                        if (typeof img.decode === 'function') {
                            img.decode().then(done).catch(done);
                        }
                    });

                    prewarmedImages.set(key, promise);
                    return promise;
                };

                const waitForImageElement = (candidate) => {
                    const src = candidate?.getAttribute('src');
                    const srcset = candidate?.getAttribute('srcset');
                    const sizes = candidate?.getAttribute('sizes');
                    return warmImage(src, srcset, sizes);
                };

                const warmTransitionLinkImages = (target) => {
                    const link = target instanceof Element
                        ? target.closest('a[data-transition-prewarm]')
                        : null;
                    if (!link) return;

                    const rawValue = link.getAttribute('data-transition-prewarm');
                    if (!rawValue) return;

                    const sources = rawValue
                        .split(',')
                        .map((item) => item.trim())
                        .filter(Boolean);
                    if (!sources.length) return;

                    void Promise.all(sources.map((src) => warmImage(src)));
                };

                document.addEventListener(
                    'pointerover',
                    (event) => warmTransitionLinkImages(event.target),
                    true,
                );
                document.addEventListener(
                    'focusin',
                    (event) => warmTransitionLinkImages(event.target),
                    true,
                );
                document.addEventListener(
                    'touchstart',
                    (event) => warmTransitionLinkImages(event.target),
                    { capture: true, passive: true },
                );

                document.addEventListener('astro:before-preparation', (event) => {
                    const transitionEvent = event;
                    if (!transitionEvent?.to?.pathname?.startsWith('/phim/')) {
                        return;
                    }

                    const originalLoader = transitionEvent.loader;
                    transitionEvent.loader = async () => {
                        await originalLoader();

                        if (transitionEvent.defaultPrevented || transitionEvent.signal?.aborted) {
                            return;
                        }

                        const nextDocument = transitionEvent.newDocument;
                        if (!nextDocument) return;

                        const criticalImages = Array.from(
                            nextDocument.querySelectorAll(
                                'img[data-transition-priority="high"], img[fetchpriority="high"]',
                            ),
                        );

                        if (!criticalImages.length) return;
                        await Promise.all(criticalImages.slice(0, 3).map(waitForImageElement));
                    };
                });
            })();
        </script>
    </head>
    <body class="min-h-screen bg-[#09090B] text-[#FAFAFA] antialiased font-sans cursor-none-custom">
        <!-- Custom Cursor -->
        <Cursor client:load />

        <!-- Noise texture overlay -->
        <div class="noise-overlay" aria-hidden="true"></div>

        <header
            class="sticky top-0 z-50 border-b border-[#2D2F35]/50 bg-[#09090B]/95"
            transition:persist
        >
            <div class="w-full px-2 sm:px-4 lg:px-6">
                <div class="max-w-384">
                    <div class="flex h-14 sm:h-16 md:h-20 items-center justify-between gap-1 sm:gap-2 md:gap-3">
                    <div class="flex min-w-0 items-center gap-2 sm:gap-3 md:gap-4">
                        <a
                            href="/"
                            class="inline-flex shrink-0 items-center border border-[#DFE104] bg-[#DFE104]/10 px-2.5 py-1.5 sm:px-3 sm:py-1.5 md:px-4 md:py-2 text-xs sm:text-sm md:text-base font-black uppercase tracking-tighter text-[#DFE104] transition-all duration-300 hover:bg-[#DFE104] hover:text-black hover:scale-105"
                            aria-label="AstroFilm Home"
                        >
                            <span class="hidden sm:inline">AstroFilm</span>
                            <span class="sm:hidden">AF</span>
                        </a>

                        <nav class="hidden items-center gap-1.5 sm:gap-2 md:flex md:gap-3 lg:gap-4" aria-label="Điều hướng chính">
                            {
                                primaryLinks.map((link) => (
                                    <a
                                        href={link.href}
                                        class="relative text-xs sm:text-xs md:text-sm font-bold uppercase tracking-tighter text-[#A1A1AA] transition-all duration-300 hover:text-[#DFE104] hover:scale-105 after:absolute after:-bottom-1 after:left-0 after:h-0.5 after:w-0 after:bg-[#DFE104] after:transition-all hover:after:w-full"
                                    >
                                        {link.label}
                                    </a>
                                ))
                            }
                            <div class="group relative">
                                <button
                                    type="button"
                                    class="inline-flex items-center gap-1 text-xs sm:text-xs md:text-sm font-bold uppercase tracking-tighter text-[#FAFAFA] transition-all duration-300 hover:text-[#DFE104] hover:scale-105"
                                >
                                    Thể loại
                                    <svg class="w-3 h-3 sm:w-3.5 sm:h-3.5 md:w-4 md:h-4 transition-transform duration-300 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                    </svg>
                                </button>
                                <div class="pointer-events-none absolute left-0 top-full z-40 -translate-y-1 pt-2 opacity-0 transition-all duration-300 group-hover:pointer-events-auto group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:translate-y-0 group-focus-within:opacity-100">
                                    <div class="w-[85vw] sm:w-80 md:w-96 max-w-[24rem] border-2 border-[#3F3F46] bg-[#09090B] p-3 sm:p-4 md:p-5">
                                        <h3 class="text-xs sm:text-xs md:text-sm font-black uppercase tracking-tighter text-[#DFE104] mb-2 sm:mb-3 md:mb-4 pb-2 border-b-2 border-[#27272A]">
                                            Thể loại nổi bật
                                        </h3>
                                        <div class="grid grid-cols-2 gap-1.5 sm:gap-2 md:gap-2.5 mb-3 sm:mb-4 md:mb-5">
                                            {
                                                genreLinks.map((genre) => (
                                                    <a
                                                        href={genre.href}
                                                        class="border-2 border-[#3F3F46] bg-[#09090B] px-2 py-1.5 sm:px-3 sm:py-2 md:px-4 md:py-2.5 text-[10px] sm:text-xs md:text-sm font-bold uppercase tracking-tighter text-[#FAFAFA] transition-all duration-300 hover:bg-[#DFE104] hover:border-[#DFE104] hover:text-black hover:scale-105"
                                                    >
                                                        {genre.label}
                                                    </a>
                                                ))
                                            }
                                        </div>
                                        <h3 class="text-xs sm:text-xs md:text-sm font-black uppercase tracking-tighter text-[#DFE104] mb-2 sm:mb-3 md:mb-4 pb-2 border-b-2 border-[#27272A]">
                                            Năm
                                        </h3>
                                        <div class="grid grid-cols-5 gap-1.5 sm:gap-2 md:gap-2.5 mb-2 sm:mb-3 md:mb-4">
                                            {
                                                yearLinks.map((year) => (
                                                    <a
                                                        href={year.href}
                                                        class="border-2 border-[#3F3F46] bg-[#09090B] px-2 py-1.5 sm:px-3 sm:py-2 md:px-4 md:py-2.5 text-[10px] sm:text-xs md:text-sm font-bold uppercase tracking-tighter text-[#FAFAFA] transition-all duration-300 hover:bg-[#DFE104] hover:border-[#DFE104] hover:text-black hover:scale-105"
                                                    >
                                                        {year.label}
                                                    </a>
                                                ))
                                            }
                                        </div>
                                        <GenreDialog client:load />
                                    </div>
                                </div>
                            </div>
                        </nav>
                    </div>

                    <div class="flex items-center gap-1 sm:gap-2">
                        <div class="hidden md:block md:w-56 lg:w-72">
                            <SearchForm client:load variant="header" />
                        </div>
                        <div class="md:hidden">
                            <SearchForm client:load variant="icon" />
                        </div>
                        <MobileMenu client:load />
                    </div>
                    </div>
                </div>
            </div>
        </header>
        <slot />
        <footer class="border-t border-[#1F2126] bg-[#09090B]">
            <div class="w-full px-4 py-6 text-center sm:px-6 sm:py-8">
                <div class="max-w-384">
                    <div class="flex flex-col items-center gap-3 sm:flex-row sm:justify-between sm:gap-4">
                        <div class="flex items-center gap-2">
                            <span class="inline-flex items-center gap-1 bg-[#DFE104] px-3 py-1 text-[10px] font-black uppercase tracking-wider text-[#09090B]">
                                AstroFilm
                            </span>
                            <span class="text-[10px] font-bold uppercase tracking-widest text-[#52525B]">© 2026</span>
                        </div>
                        <p class="text-[10px] font-semibold uppercase tracking-[0.2em] text-[#52525B]">
                            Built for learning • Not commercial
                        </p>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>
