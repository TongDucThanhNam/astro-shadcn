---
interface Props {
    title: string;
}
const { title } = Astro.props;
import { ClientRouter } from "astro:transitions";
import ProgressBar from "astro-vtbot/components/ProgressBar.astro";

import "@/styles/globals.css";
import SearchForm from "@/components/SearchForm";
import { NavigationMenuDemo } from "@/components/NavigationMenuDemo";
import MobileMenu from "@/components/MobileMenu";
import Cursor from "@/components/ui/Cursor";
---

<!doctype html>
<html lang="vi">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="AstroFlim - Xem phim online miễn phí" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
        <ProgressBar />
    </head>
    <body class="min-h-screen bg-[#09090B] text-[#FAFAFA] antialiased font-sans cursor-none-custom">
        <!-- Custom Cursor -->
        <Cursor client:load />

        <!-- Noise texture overlay -->
        <div class="noise-overlay" aria-hidden="true"></div>

        <nav
            class="sticky top-0 z-50 border-b-2 border-[#3F3F46] bg-[#09090B]/90 backdrop-blur-sm transition-all duration-300"
            transition:persist
        >
            <div
                class="mx-auto flex w-full max-w-[95vw] flex-col gap-4 px-4 py-4 md:flex-row md:items-center md:justify-between"
            >
                <div
                    class="flex w-full items-center justify-between gap-3 md:w-auto md:justify-start"
                >
                    <a
                        href="/"
                        class="flex flex-shrink-0 items-center gap-2 transition-all duration-200 hover:opacity-80"
                        aria-label="AstroFlim Home"
                    >
                        <span
                            class="bg-[#DFE104] px-4 py-2 text-sm font-bold uppercase tracking-wider text-[#09090B]"
                        >
                            AstroFlim
                        </span>
                    </a>
                    <div class="flex items-center gap-2 md:hidden">
                        <SearchForm client:only="react" variant="icon" />
                        <MobileMenu client:only="react" />
                    </div>
                </div>
                <div
                    class="hidden w-full md:flex md:flex-1 md:items-center md:gap-2 lg:gap-6"
                >
                    <NavigationMenuDemo client:only="react" />
                </div>
                <div
                    class="hidden w-full md:block md:w-auto md:max-w-sm md:flex-1 lg:flex-none lg:w-80"
                >
                    <SearchForm client:only="react" />
                </div>
            </div>

            <!-- Mobile Navigation below header -->
            <div class="md:hidden px-4 pb-4">
                <NavigationMenuDemo client:only="react" />
            </div>
        </nav>
        <slot />
        <footer
            class="flex flex-col items-center justify-center w-full bg-[#09090B] py-12 border-t-2 border-[#3F3F46]"
        >
            <div class="flex items-center gap-2 mb-4">
                <span class="bg-[#DFE104] px-3 py-1 text-xs font-bold uppercase tracking-wider text-[#09090B]">
                    AstroFlim
                </span>
            </div>
            <p class="text-sm text-[#A1A1AA] text-center max-w-md uppercase tracking-wide">
                Trang web được làm với mục đích học tập và phi thương mại.
            </p>
            <p class="text-xs text-[#A1A1AA]/60 mt-4 uppercase tracking-widest text-[10px]">
                Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-[#DFE104] hover:text-[#DFE104]/80 transition-colors">Astro</a> & <a href="https://ui.shadcn.com" target="_blank" rel="noopener noreferrer" class="text-[#DFE104] hover:text-[#DFE104]/80 transition-colors">shadcn/ui</a>
            </p>
        </footer>
    </body>
</html>
