---
import Layout from '@/layouts/Layout.astro';
import MovieCard from '@/components/MovieCard.astro';
import {
  Pagination,
  PaginationContent,
  PaginationItem,
  PaginationLink,
  PaginationNext,
  PaginationPrevious,
} from '@/components/ui/pagination';
import { CACHE_CONFIGS, getCacheHeaders } from '@/lib/cache';
import {
  getListByType,
  listQueryFromRequest,
  parseListQuery,
  type ListItem,
} from '@/lib/phimapi';

const { type } = Astro.params;

if (!type) {
  throw new Error('Missing list type.');
}

const requestUrl = new URL(Astro.request.url);
const queryInput = listQueryFromRequest(requestUrl.searchParams);
const query = parseListQuery(queryInput, { limit: 10 });

for (const [key, value] of Object.entries(getCacheHeaders(CACHE_CONFIGS.QUERY_PAGES))) {
  Astro.response.headers.set(key, value);
}

const data = await getListByType(type, query);
const movies = data.data.items;
const currentPage = query.page;
const totalPages = data.data.params.pagination.totalPages;
if (totalPages > 0 && currentPage > totalPages) {
  return Astro.redirect(`/danh-sach/${type}?page=${totalPages}`, 302);
}
const typeLabel = type
  .split('-')
  .filter(Boolean)
  .map((word) => word[0].toUpperCase() + word.slice(1))
  .join(' ');

function getPageUrl(pageNum: number) {
  if (pageNum <= 1) return `/danh-sach/${type}`;
  return `/danh-sach/${type}?page=${pageNum}`;
}
---

<Layout title={`${typeLabel || type} - Trang ${currentPage}`}>
  <main>
    <div class="mx-auto mt-2 w-full max-w-7xl px-3 sm:px-6 lg:px-8">
      <section class="flex flex-col gap-5 py-6 sm:py-8 md:py-10">
        <header class="flex items-end justify-between gap-3 border-b border-[#27272A] pb-3">
          <div>
            <p class="text-xs uppercase tracking-[0.18em] text-[#71717A]">Danh sach</p>
            <h1 class="text-lg font-semibold uppercase tracking-tight text-[#FAFAFA] sm:text-2xl">
              {typeLabel || type}
            </h1>
          </div>
          <span class="rounded border border-[#3F3F46] bg-[#18181B] px-2 py-1 text-xs font-semibold text-[#A1A1AA]">
            Trang {currentPage}/{Math.max(totalPages, 1)}
          </span>
        </header>

        <div class="w-full">
          <div class="grid grid-cols-2 gap-3 sm:gap-5 md:grid-cols-4 lg:grid-cols-5">
            {
              movies.map((item: ListItem, index: number) => (
                <MovieCard
                  index={index}
                  slug={item.slug}
                  name={item.name}
                  image={item.poster_url}
                  year={item.year.toString()}
                />
              ))
            }
          </div>

          {
            movies.length === 0 && (
              <div class="mt-8 rounded border border-[#27272A] bg-[#09090B] px-4 py-8 text-center text-sm text-[#A1A1AA]">
                Khong co du lieu cho trang nay.
              </div>
            )
          }
        </div>

        <div class="mt-2 sm:mt-4">
          <Pagination>
            <PaginationContent class="flex-wrap justify-center gap-2 sm:gap-1">
              {
                currentPage > 1 && (
                  <PaginationItem>
                    <PaginationPrevious href={getPageUrl(currentPage - 1)} />
                  </PaginationItem>
                )
              }

              <PaginationItem>
                <PaginationLink isActive={true} href={getPageUrl(currentPage)}
                  >{currentPage}</PaginationLink
                >
              </PaginationItem>

              {
                currentPage < totalPages && (
                  <PaginationItem>
                    <PaginationLink href={getPageUrl(currentPage + 1)}>
                      {currentPage + 1}
                    </PaginationLink>
                  </PaginationItem>
                )
              }

              {
                currentPage < totalPages - 1 && (
                  <PaginationItem>
                    <PaginationLink href={getPageUrl(currentPage + 2)}>
                      {currentPage + 2}
                    </PaginationLink>
                  </PaginationItem>
                )
              }

              {
                currentPage < totalPages && (
                  <PaginationItem>
                    <PaginationNext href={getPageUrl(currentPage + 1)} />
                  </PaginationItem>
                )
              }
            </PaginationContent>
          </Pagination>
        </div>
      </section>
    </div>
  </main>
</Layout>
