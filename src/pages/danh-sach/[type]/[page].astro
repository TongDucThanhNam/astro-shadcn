---
const { type, page } = Astro.params;

if (!type) {
  throw new Error('Missing list type.');
}

const numericPage = Number(page);
const normalizedPage = Number.isInteger(numericPage) && numericPage > 1 ? numericPage : 1;

const requestUrl = new URL(Astro.request.url);
const redirectUrl = new URL(`/danh-sach/${type}`, requestUrl);

for (const [key, value] of requestUrl.searchParams.entries()) {
  redirectUrl.searchParams.set(key, value);
}

if (normalizedPage > 1) {
  redirectUrl.searchParams.set('page', String(normalizedPage));
} else {
  redirectUrl.searchParams.delete('page');
}

return Astro.redirect(`${redirectUrl.pathname}${redirectUrl.search}`, 301);
---
