---
import HeroMovie from '@/components/HeroMovie.astro';
import Layout from '../layouts/Layout.astro';
import BatchedHomeSections from '@/components/ui/sections/BatchedHomeSections.astro';
import { parseFeedVersion } from '@/lib/phimapi';

const requestUrl = new URL(Astro.request.url);
const feedVersion = parseFeedVersion(requestUrl.searchParams.get('feed'));
---

<Layout title="AstroFlim Prime">
    <main class="mx-auto w-full max-w-[96rem] px-2 pb-20 text-white sm:px-3 lg:px-4">
        <!-- Hero Movie Section -->
        <HeroMovie feedVersion={feedVersion} />

        <BatchedHomeSections />
    </main>
</Layout>
