---
import SearchMovieGrid from '@/components/SearchMovieGrid.astro';
import Layout from '@/layouts/Layout.astro';
import { CACHE_CONFIGS, getCacheHeaders } from '@/lib/cache';
import { listQueryFromRequest } from '@/lib/phimapi';

const requestUrl = new URL(Astro.request.url);
const searchParams = requestUrl.searchParams;
const filters = listQueryFromRequest(searchParams);

for (const [key, value] of Object.entries(getCacheHeaders(CACHE_CONFIGS.QUERY_PAGES))) {
  Astro.response.headers.set(key, value);
}
---

<Layout title="Astro flim.">
    <main>
        <div class="flex flex-col items-center mt-2">
            <!-- Movies Grid -->
            <div class="mx-4 sm:mx-6 md:mx-8 lg:mx-12 xl:mx-20">
                <SearchMovieGrid filters={filters} />
            </div>
        </div>
    </main>
</Layout>
