{
  "name": "astro-shadcn",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "ui:map": "bun scripts/generate-ui-map.ts --src src --entry src/pages/index.astro --alias @=src --format ascii",
    "ai:check": "bun scripts/check-ai-contracts.ts --src src",
    "tw:check": "bun scripts/check-tailwind-safety.ts --src src",
    "ai:pack": "bun scripts/context-pack.ts --out .ai/context.txt",
    "format": "biome format --write --files-ignore-unknown=true .",
    "lint:biome": "biome check --files-ignore-unknown=true .",
    "lint:ai": "bun run ai:check && bun run tw:check"
  },
  "devDependencies": {
    "@babel/parser": "^7.28.4",
    "@babel/traverse": "^7.28.4",
    "@biomejs/biome": "^1.9.4"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/node": "^9.5.4",
    "@astrojs/react": "^4.4.2",
    "@astrojs/vercel": "^9.0.4",
    "@mediafox/core": "^1.0.4",
    "@mediafox/react": "^1.0.4",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vidstack/react": "^1.12.13",
    "astro": "^5.17.3",
    "astro-imagetools": "^0.9.0",
    "astro-vtbot": "^2.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.34.3",
